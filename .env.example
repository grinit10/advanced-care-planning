# =============================================================================
# Azure OpenAI — Required for the LLM (get these from Azure Portal > Azure OpenAI > Keys)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-10-01-preview

# Model deployment name (must match what you deployed in Azure AI Foundry)
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4.1-mini-aus

# Optionally separate the extraction model for reasoning and structured JSON output (e.g. gpt-5.4-mini-aus):
# AZURE_OPENAI_EXTRACTOR_LLM_DEPLOYMENT=


# =============================================================================
# Groq — Optional for low-latency Voice LLM (uses the Sydney LPU cluster)
# Get your API key at: https://console.groq.com
# =============================================================================
# GROQ_API_KEY=
# GROQ_VOICE_MODEL=llama-3.1-8b-instant

# =============================================================================
# Deepgram — Required for STT (speech-to-text) and TTS (text-to-speech)
# Uses the Australian endpoint (api.au.deepgram.com) — data stays in Sydney
# Get your API key at: https://console.deepgram.com
# =============================================================================
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# =============================================================================
# Azure Communication Services Email — Optional (for email delivery of plans)
# Create an ACS resource in Azure Portal, add an email domain, then paste:
#   Connection string from "Primary Key" page
#   Sender domain from "Email > Domains" page
# =============================================================================
# ACS_CONNECTION_STRING=endpoint=https://your-resource.communication.azure.com;accesskey=abc123...
# ACS_SENDER_DOMAIN=DoNotReply@abc123.azurecomm.net

# =============================================================================
# LiveKit — Local development defaults
# =============================================================================
LIVEKIT_URL=ws://livekit-server:7880
LIVEKIT_API_KEY=APIoSBh5JqSGNUC
LIVEKIT_API_SECRET=Y4A9W5VgUcmedACbKKH49FXFzKuMVXqZofrc2B2q1R6

# Your host machine's LAN IP — needed by LiveKit for WebRTC ICE candidates.
# Auto-detected by running:
#   ./setup.sh        (Linux/macOS)
#   .\setup.ps1       (Windows)
# Or set it manually: HOST_IP=192.168.1.42
HOST_IP=

# =============================================================================
# Recordings — Local storage for conversation audio
# =============================================================================
RECORDINGS_DIR=recordings